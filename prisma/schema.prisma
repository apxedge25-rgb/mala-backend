// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// FINAL Prisma schema for Mala.ai MVP
/// History matches EXISTING database columns ONLY

model History {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Text
  title       String?  @db.Text
  screenText  String   @map("screen_text") @db.Text
  explanation String   @db.Text
  transcript  Json     @db.JsonB
  createdAt   DateTime @map("created_at") @default(now())
  updatedAt   DateTime @map("updated_at") @default(now()) @updatedAt

  @@map("history")
  @@index([createdAt], name: "idx_history_created_at")
}

model UserSetting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Text
  userId    String   @unique @map("user_id") @db.Text
  language  String   @default("en") @db.Text
  createdAt DateTime @map("created_at") @default(now())
  updatedAt DateTime @map("updated_at") @default(now()) @updatedAt

  @@map("user_settings")
}

model PdfDocument {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Text
  userId      String?          @map("user_id") @db.Text
  filename    String           @db.Text
  storagePath String?          @map("storage_path") @db.Text
  pages       Int?             @db.Integer
  sizeBytes   Int?             @map("size_bytes") @db.Integer
  textPreview String?          @map("text_preview") @db.Text
  createdAt   DateTime         @map("created_at") @default(now())
  updatedAt   DateTime         @map("updated_at") @default(now()) @updatedAt

  explanations PdfExplanation[]

  @@map("pdf_document")
  @@index([userId], name: "idx_pdfdocument_user_id")
}

model PdfExplanation {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Text
  pdfId        String        @map("pdf_id") @db.Text
  pdf          PdfDocument   @relation(fields: [pdfId], references: [id], onDelete: Cascade)
  userId       String?       @map("user_id") @db.Text
  prompt       String        @db.Text
  responseText String        @map("response_text") @db.Text
  tokensUsed   Int?          @map("tokens_used") @db.Integer
  createdAt    DateTime      @map("created_at") @default(now())

  @@map("pdf_explanation")
  @@index([pdfId], name: "idx_pdfexplanation_pdf_id")
  @@index([userId], name: "idx_pdfexplanation_user_id")
}
